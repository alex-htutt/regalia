# Regalia configuration — OPTIONAL. Everything below can be set from the app's
# Settings view instead (stored in the gitignored dashboard/.config.json), so a
# .env is only for people who prefer managing their own environment. When a
# value is set in both places, the environment variable wins.
# NOTHING here is required for the core dashboard; each section lights up a feature.

# ── fast tier — local Ollama (free, private) ────────────────────────────────
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# ── smart tier — Anthropic API (API-credit billed; powers agent tool loops) ─
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-8

# ── openai tier — OpenAI API (ChatGPT models) ───────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=                # leave unset for the app default
# OPENAI_BASE=https://api.openai.com/v1   # any OpenAI-compatible endpoint

# ── claude tier — Claude Code CLI (billed to your Claude subscription) ──────
# The CLI must be installed and signed in (`claude` on PATH, or set CLAUDE_CLI).
# CLAUDE_CLI=claude
# CLAUDE_CLI_MODEL=            # empty = your plan's default model
# CLAUDE_CLI_TIMEOUT=180       # seconds, wall-clock watchdog per run
# CLAUDE_CLI_CWD=              # working dir that bounds the CLI's file access
#                              # (env-only on purpose — not settable from the UI)

# ── Inbox (Gmail / Outlook) — read + drafts only; nothing can send ──────────
# Easiest path: paste the Google client_secret.json and the Azure app id
# straight into Settings → Email, then click Connect. The env route below does
# the same thing. Per-account tokens land in the gitignored dashboard/.email_tokens/.
# GMAIL_OAUTH_CLIENT=/path/to/client_secret.json   # Google Cloud "Desktop app" client
# MS_OAUTH_CLIENT_ID=...                           # Azure public-client app id
# MS_OAUTH_TENANT=consumers                        # personal Outlook.com accounts

# ── Misc ─────────────────────────────────────────────────────────────────────
# NEWS_TTL=1800   # briefing cache, seconds
# REGALIA_VAULT=  # vault folder override (also settable in Settings → Advanced)
