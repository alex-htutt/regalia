# Regalia configuration — copy to .env (or set in your shell) and fill in what you use.
# NOTHING here is required for the core dashboard; each section lights up a feature.
# All values can also be managed from the in-app Settings view (stored in the
# gitignored dashboard/.config.json; env vars still win for the OAuth client creds).

# ── fast tier — local Ollama (free, private) ────────────────────────────────
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# ── smart tier — Anthropic API (API-credit billed; powers agent tool loops) ─
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-8

# ── openai tier — OpenAI API (ChatGPT models) ───────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=  # leave unset for the app default

# ── claude tier — Claude Code CLI (billed to your Claude subscription) ──────
# The CLI must be installed and signed in (`claude` on PATH, or set CLAUDE_CLI).
# CLAUDE_CLI=claude
# CLAUDE_CLI_MODEL=            # empty = your plan's default model
# CLAUDE_CLI_TIMEOUT=180       # seconds, wall-clock watchdog per run

# ── Inbox (Gmail / Outlook) — read + drafts only; nothing can send ──────────
# One-time OAuth app setup, then connect accounts from Settings (or
# `python connect_email.py gmail|outlook`). Tokens land in the gitignored
# dashboard/.email_tokens/.
# GMAIL_OAUTH_CLIENT=/path/to/client_secret.json   # Google Cloud "Desktop app" client
# MS_OAUTH_CLIENT_ID=...                           # Azure public-client app id
# MS_OAUTH_TENANT=consumers                        # personal Outlook.com accounts

# ── Misc ─────────────────────────────────────────────────────────────────────
# NEWS_TTL=1800   # briefing cache, seconds
