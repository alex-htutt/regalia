# --- Secrets (never commit) ---
.env
*.env
.env.*
*.key
*secret*
# ...but DO commit the template so others know what to fill in
!.env.example
!**/.env.example

# --- Claude Code per-machine settings (personal paths + local permissions) ---
**/.claude/settings.local.json

# --- Python / dashboard ---
__pycache__/
*.py[cod]
.venv/
venv/
env/
dist/
build/
*.egg-info/

# --- Obsidian (per-machine UI state & cache) ---
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/cache
.trash/

# --- OS cruft ---
.DS_Store
Thumbs.db
Desktop.ini

# --- Logs ---
*.log

# --- Chat attachments (per-session uploads; never committed) ---
dashboard/.chat_attachments/

# --- Chat transcripts (multi-chat store; personal, never committed) ---
dashboard/.chats/

# --- Email OAuth tokens + client secrets (per-account; never committed) ---
dashboard/.email_tokens/
dashboard/client_secret*.json
dashboard/*.oauth.json

# --- Cloned external repos ---
codex-plugin-cc/

# --- Tailwind standalone CLI binary (~108MB; re-fetch via dashboard/get-tailwind.bat) ---
dashboard/tools/tailwindcss*
dashboard/tools/*.exe

# --- Private content: only the skeleton (dashboard + vault framework) is pushed ---
# Classes, internships, personal projects, persona files, and the resume stay local only.
Internship-Projects/
schoolwork/
Roblox_Dev/
My_Evil_Twin/
Resume/

# --- Vendored third-party reading material (own license; fetch upstream instead) ---
research/RAG-pipelines/resources/ai-system-design-guide-main/

# --- Regalia settings store (may hold API keys; per-machine) ---
dashboard/.config.json
dashboard/.external.json

# --- PyInstaller build outputs (regalia.spec stays tracked) ---
dashboard/build/
dashboard/dist/
