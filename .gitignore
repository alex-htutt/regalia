# --- Secrets (never commit) ---
.env
*.env
.env.*
*.key
*secret*
# ...but DO commit the template so others know what to fill in
!.env.example
!**/.env.example

# --- Python / dashboard ---
__pycache__/
*.py[cod]
.venv/
venv/
env/
dist/
build/
*.egg-info/

# --- Obsidian (per-machine UI state & cache) ---
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/cache
.trash/

# --- OS cruft ---
.DS_Store
Thumbs.db
Desktop.ini

# --- Logs ---
*.log

# --- Chat attachments (per-session uploads; never committed) ---
dashboard/.chat_attachments/

# --- Email OAuth tokens + client secrets (per-account; never committed) ---
dashboard/.email_tokens/
dashboard/client_secret*.json
dashboard/*.oauth.json

# --- Cloned external repos ---
codex-plugin-cc/

# --- Tailwind standalone CLI binary (~108MB; re-fetch via dashboard/get-tailwind.bat) ---
dashboard/tools/tailwindcss*
dashboard/tools/*.exe

# --- Evil Twin persona files (personal; not committed) ---
My_Evil_Twin/me.md
My_Evil_Twin/twin.md

# --- Treasury scraper generated data (backfill / live archives; regenerable) ---
Internship-Projects/Essex_Securities/treasury_web_scraper/data/
