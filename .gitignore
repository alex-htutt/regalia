# --- Secrets (never commit) ---
.env
*.env
.env.*
*.key
*secret*

# --- Python / dashboard ---
__pycache__/
*.py[cod]
.venv/
venv/
env/
dist/
build/
*.egg-info/

# --- Obsidian (per-machine UI state & cache) ---
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/cache
.trash/

# --- OS cruft ---
.DS_Store
Thumbs.db
Desktop.ini

# --- Logs ---
*.log

# --- Chat attachments (per-session uploads; never committed) ---
dashboard/.chat_attachments/

# --- Cloned external repos ---
codex-plugin-cc/

# --- Tailwind standalone CLI binary (~108MB; re-fetch via dashboard/get-tailwind.bat) ---
dashboard/tools/tailwindcss*
dashboard/tools/*.exe
